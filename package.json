{
  "name": "overleaf-snapshot-to-github",
  "private": true,
  "version": "0.4.0-alpha.3",
  "type": "module",
  "description": "Chrome extension that commits Overleaf project snapshots to a GitHub repository, with optional live read-only sync.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdullahkavakli/Overleaf-Snapshot-to-GitHub.git"
  },
  "bugs": {
    "url": "https://github.com/abdullahkavakli/Overleaf-Snapshot-to-GitHub/issues"
  },
  "homepage": "https://github.com/abdullahkavakli/Overleaf-Snapshot-to-GitHub#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:no-typecheck": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
